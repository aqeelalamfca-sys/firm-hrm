# =============================================================================
# Production environment variables for ana-ca.com (Hostinger VPS)
# This file is a TEMPLATE only — commit it to git.
# The real deploy/.env is NEVER committed (it's in .gitignore).
# When deploying from Replit, scripts/deploy.sh uploads secrets automatically.
# =============================================================================

# PostgreSQL password for the ana_hrm database
# Generate: openssl rand -base64 32 | tr -dc 'a-zA-Z0-9' | head -c 28
DB_PASSWORD=your_strong_password_here

# JWT secret for signing authentication tokens
# Generate: openssl rand -hex 32
JWT_SECRET=your_jwt_secret_here

# Application-level encryption key
# Generate: openssl rand -hex 32
ENCRYPTION_KEY=your_encryption_key_here
